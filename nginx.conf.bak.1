server {
    listen 80;
    server_name sharpishly.vm;
    root /var/www/html/website; # Standardized root to match Docker Compose
    index index.html index.php;

    # --- LOGGING CENTRALIZATION ---
    # Points to your storage folder in the php directory
    access_log /var/www/html/storage/logs/nginx_access.log;
    error_log  /var/www/html/storage/logs/nginx_error.log warn;


    # FIX 1: Allow larger files (Set to 50MB)
    client_max_body_size 50M;

    # 1. THE SPA HANDLER
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 2. THE NERVOUS SYSTEM & DIRECT PHP FILES
    # This handles specific .php files (like nervous_system.php)
    location ~ \.php$ {
        fastcgi_pass php:9000;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME /var/www/html$fastcgi_script_name;
        include fastcgi_params;
    }

    # 3. THE MVC API HANDLER
    # This sends abstract routes (/php/user/profile) to your index.php FrontController
    location /php/ {
        #try_files $uri $uri/ /php/index.php?$query_string;
        try_files $uri $uri/ /php/index.php$is_args$query_string;
    }

    # Security: deny access to sensitive folders
    location ~ ^/(src|logs|\.env|\.git|storage) {
        deny all;
        return 403;
    }
}
